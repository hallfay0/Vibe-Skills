  "compatibility_exit_policy": {
    "version": 1,
    "purpose": "Freeze the rule that compatibility layers can translate or wire hosts, but must not regain live semantic authority. Also declares explicit deletion budgets for each migration phase.",
    "non_negotiable_rules": [
      {
        "id": "no-new-live-semantic-authority",
        "applies_to_authority_layers": [
          "entry_wrapper",
          "host_adapter"
        ],
        "forbidden_change_classes": [
          "task_meaning",
          "skill_selection",
          "plan_construction",
          "verification_semantics"
        ],
        "allowed_roles": [
          "entry delegation",
          "projection only",
          "host wiring",
          "leaf execution bridge",
          "historical contract reader"
        ],
        "review_requirement": "Any change in these layers must name the kernel-facing owner and prove that the layer only delegates, projects, or wires a host edge."
      },
      {
        "id": "zero-expansion-budget",
        "applies_to_authority_layers": [
          "entry_wrapper",
          "host_adapter"
        ],
        "rule": "Migration phases may remove compatibility residue, but they must not introduce new compatibility-owned semantic capabilities."
      }
    ],
    "controlled_capabilities": [
      {
        "capability": "public_entry",
        "authority_layer": "entry_wrapper",
        "kernel_owner_capabilities": [
          "plan_construction",
          "execution",
          "verification",
          "run_state"
        ],
        "allowed_change_roles": [
          "entry delegation",
          "request normalization",
          "summary projection"
        ],
        "deletion_target_phase": "phase_4"
      },
      {
        "capability": "host_wiring",
        "authority_layer": "host_adapter",
        "kernel_owner_capabilities": [],
        "allowed_change_roles": [
          "host wiring",
          "leaf execution bridge"
        ],
        "deletion_target_phase": "retain"
      }
    ],
    "phase_deletion_budgets": [
      {
        "phase": "phase_1",
        "minimum_retirements": 0,
        "maximum_new_compatibility_capabilities": 0,
        "focus": "freeze the inventory and stop semantic expansion before larger cuts"
      },
      {
        "phase": "phase_2",
        "minimum_retirements": 1,
        "maximum_new_compatibility_capabilities": 0,
        "focus": "remove at least one local-skill or admission-related compatibility residue"
      },
      {
        "phase": "phase_3",
        "minimum_retirements": 2,
        "maximum_new_compatibility_capabilities": 0,
        "focus": "remove route-led planning or execution residue while the kernel hot path becomes authoritative"
      },
      {
        "phase": "phase_4",
        "minimum_retirements": 3,
        "maximum_new_compatibility_capabilities": 0,
        "focus": "leave only explicit thin projections, host edges, or historical release shims"
      }
    ]
  },
