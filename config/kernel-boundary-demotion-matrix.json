  "migration_scaffold_retirement_protocol": {
    "purpose": "Prevent migration-only governance assets from becoming a second heavy control plane after they helped demote the old router surfaces.",
    "governed_assets": [
      "config/kernel-benchmark-pack.json",
      "config/kernel-evaluation-metrics.json",
      "config/kernel-boundary-demotion-matrix.json"
    ],
    "rules": [
      "Prefer extending an existing governance surface over creating a net-new migration contract file.",
      "A migration slice should not add more governance-edit burden than the semantic authority it removes from the old route-first system.",
      "By phase_4, migration-only governance surfaces should be shrinking, generated, historicalized, or otherwise easier to maintain than the router era they replaced.",
      "After phase_4, the live governance surface should stay capped at the benchmark pack, metric config, and boundary demotion map; anything wider should be generated, historical, or artifact-only."
    ],
    "change_budget": {
      "maximum_net_new_governance_contract_files_per_slice": 0,
      "default_preferred_governance_files_touched_per_slice": 1
    },
    "claim_rule": "Do not call the architecture lighter if each semantic change still requires maintaining an expanding stack of migration-only governance assets."
  }
